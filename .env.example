# OpenAI API access
OPENAI_API_KEY=

# Model used when OPENAI_API_KEY is present.
AI_MODEL=gpt-5-mini

# Optional: use any OpenAI-compatible API instead of OpenAI directly.
# Example providers often require their own API key and base URL.
AI_API_KEY=
AI_BASE_URL=
AI_PROVIDER_NAME=

# Optional: used for provider headers and deployment docs.
APP_BASE_URL=http://localhost:3000
